generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id          String   @id @default(cuid())
  plateNumber String   @unique
  make        String
  model       String
  year        Int
  color       String?
  vin         String?  @unique
  status      String   @default("ACTIVE") // ACTIVE, MAINTENANCE, OUT_OF_SERVICE, SOLD
  department  String?
  driverName  String?
  driverPhone String?
  fuelType    String?  // PETROL, DIESEL, ELECTRIC, HYBRID
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  maintenanceRecords MaintenanceRecord[]
}

model MaintenanceRecord {
  id                   String    @id @default(cuid())
  vehicleId            String
  maintenanceDate      DateTime
  description          String
  type                 String    // OIL_CHANGE, TIRE, ELECTRICAL, MECHANICAL, BODYWORK, AC, TRANSMISSION, BRAKES, FILTER, BATTERY, SUSPENSION, OTHER
  cost                 Float
  kilometerReading     Float?
  serviceProvider      String?
  invoiceNumber        String?
  laborCost            Float?
  partsCost            Float?
  nextMaintenanceDate  DateTime?
  nextMaintenanceKm    Float?
  priority             String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status               String    @default("COMPLETED") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}
